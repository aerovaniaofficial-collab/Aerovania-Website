Options -Indexes
RewriteEngine On

# ── Force HTTPS ──────────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ── Force www ────────────────────────────────────────────────
RewriteCond %{HTTP_HOST} ^aerovania\.com$ [NC]
RewriteRule ^(.*)$ https://www.aerovania.com/$1 [R=301,L]

# ── Remove index.html from root ──────────────────────────────
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# ── Remove .html extension from all URLs ─────────────────────
# If the request is for a real file or directory, skip
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# If the URL has no extension, try adding .html
RewriteRule ^([^.]+)$ $1.html [L]

# Redirect .html URLs to clean URLs (301 permanent)
RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ── Custom 404 ───────────────────────────────────────────────
ErrorDocument 404 /index.html
