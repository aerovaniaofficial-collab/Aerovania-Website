# Copy this file to .env and fill in your values
PORT=3001

# SMTP credentials (Gmail example — use an App Password, not your main password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Where contact/career emails get delivered
RECEIVER_EMAIL=info@aerovania.com

# Allowed frontend origins (comma-separated)
CORS_ORIGIN=http://localhost:5500,http://localhost:3001,http://127.0.0.1:5500

# Admin panel secret key (choose any strong random string)
ADMIN_KEY=change-this-to-a-strong-secret
